<%- include('../../partials/header') %>
<%- include('../../partials/nav') %>

<section class="profile-background">
<main id="profileBox" class="profile">

  <div class="profile-section">

    <div class="profile-layout">

      <!-- LEFT SIDE -->
      <div class="profile-left-side">

        <div class="profile-info-box">

          <h2>Profile for: <br><%= user.usernameProfi || user.username %></h2>

          <!-- PROFILE IMAGE FORM -->
          <form class="profile-img" action="/profile/image" method="POST" enctype="multipart/form-data">

            <input 
              type="file" 
              id="profileUpload" 
              name="avatar" 
              accept="image/png, image/jpeg"
              hidden
            >

            <div class="profile-image-wrapper">

              <% if (user.profileImage) { %>
                <img 
                  class="profile-main-img" 
                  src="<%= user.profileImage %>" 
                  alt="<%= user.usernameProfi || user.username %>'s profile picture"
                >
              <% } else { %>
                <div class="profile-main-img profile-placeholder">
                  No profile image yet.
                </div>
              <% } %>

              <label 
                for="profileUpload" 
                class="upload-btn profile-upload-icon overlay-camera" 
                aria-label="Upload profile image"
              >
                📷
              </label>

            </div>

            <button class="button-res profile" type="submit">
              Upload Picture
            </button>

          </form>

          <!-- DOB BOX -->
          <div class="dob-box">

            <form action="/profile/dob" method="post" class="neon-form dob-form">

              <label for="dob">Date of Birth:</label>

              <input 
                type="date"
                id="dob"
                name="dob"
                class="dob-input"
                value="<%= user.dob ? user.dob.toISOString().split('T')[0] : '' %>"
                required
              >

              <button type="submit" class="button-res">
                Save Date of Birth
              </button>

              <p class="dob-display">
                <span>Your Date of Birth:</span>
                <%= user.dob ? user.dob.toLocaleDateString("en-GB") : "Not set yet" %>
              </p>

            </form>

          </div>

        </div>

      </div>

  
         <!-- RIGHT SIDE -->
      <div class="profile-right-side">

        <section class="chat-history">

          <h2 class="profileTitle">My Chat History</h2>

          <% if (messages && messages.length > 0) { %>

            <%
              // Group messages into pairs: user message + generator response
              const chatPairs = [];
              const orderedMessages = [...messages];

              for (let i = 0; i < orderedMessages.length; i++) {
                const currentMessage = orderedMessages[i];

                if (currentMessage.sender === "user") {
                  const nextMessage = orderedMessages[i + 1];

                  if (nextMessage && nextMessage.sender !== "user") {
                    chatPairs.push({
                      user: currentMessage,
                      generator: nextMessage
                    });

                    i++;
                  } else {
                    chatPairs.push({
                      user: currentMessage,
                      generator: null
                    });
                  }
                } else {
                  chatPairs.push({
                    user: null,
                    generator: currentMessage
                  });
                }
              }

              // Show newest conversations first
              const reversedPairs = [...chatPairs].reverse();
            %>

            <!-- SLIDER BUTTON LEFT -->
            <button 
              type="button" 
              class="chat-slider-btn chat-slider-prev" 
              id="chatPrevBtn"
              aria-label="Previous chat"
            >
              ‹
            </button>

            <!-- ONE SLIDER WRAPPER FOR ALL CARDS -->
            <div class="history" id="chatSlider">

              <% reversedPairs.forEach(pair => { %>

                <div class="history-card chat-pair-card">

                  <% if (pair.user) { %>
                    <div class="chat-message-block user-history">
                      <strong>You:</strong>
                      <p><%= pair.user.text %></p>
                    </div>
                  <% } %>

                  <% if (pair.generator) { %>
                    <div class="chat-message-block generator-history">
                      <strong>Generator:</strong>
                      <p><%= pair.generator.text %></p>
                    </div>
                  <% } %>

                </div>

              <% }) %>

            </div>

            <!-- SLIDER BUTTON RIGHT -->
            <button 
              type="button" 
              class="chat-slider-btn chat-slider-next" 
              id="chatNextBtn"
              aria-label="Next chat"
            >
              ›
            </button>

            <!-- DOTS -->
            <div class="chat-slider-dots" id="chatSliderDots"></div>

          <% } else { %>

            <p>No chat history yet.</p>

          <% } %>

        </section>

      </div> <!-- closes profile-right-side -->

    </div> <!-- closes profile-layout -->

  </div> <!-- closes profile-section -->

</main>
</section>


<%- include('../../partials/mobileBottomNav') %>

<script>
  // Get the slider elements from the page
  const chatSlider = document.getElementById("chatSlider");
  const prevButton = document.getElementById("chatPrevBtn");
  const nextButton = document.getElementById("chatNextBtn");
  const dotsBox = document.getElementById("chatSliderDots");

  // Only run this code if the chat slider exists on the page
  if (chatSlider && prevButton && nextButton && dotsBox) {

    // Get all chat cards
    const cards = chatSlider.querySelectorAll(".history-card");

    // This keeps track of which card we are viewing
    let currentCard = 0;

    // Create one dot for each card
    cards.forEach(function (card, index) {
      const dot = document.createElement("button");

      dot.type = "button";
      dot.className = "chat-slider-dot";

      // Make the first dot active at the start
      if (index === 0) {
        dot.classList.add("active");
      }

      // When the user clicks a dot, move to that card
      dot.addEventListener("click", function () {
        currentCard = index;
        moveSlider();
      });

      dotsBox.appendChild(dot);
    });

    // Move to the next card
    nextButton.addEventListener("click", function () {
      if (currentCard < cards.length - 1) {
        currentCard++;
        moveSlider();
      }
    });

    // Move to the previous card
    prevButton.addEventListener("click", function () {
      if (currentCard > 0) {
        currentCard--;
        moveSlider();
      }
    });

    // This function moves the slider and updates the dots
    function moveSlider() {
      const cardWidth = cards[0].offsetWidth;
      const gap = 24; // same as the CSS gap in .history
      const moveAmount = cardWidth + gap;

      chatSlider.scrollTo({
        left: currentCard * moveAmount,
        behavior: "smooth"
      });

      updateDots();
    }

    // This function changes which dot is active
    function updateDots() {
      const dots = dotsBox.querySelectorAll(".chat-slider-dot");

      dots.forEach(function (dot, index) {
        if (index === currentCard) {
          dot.classList.add("active");
        } else {
          dot.classList.remove("active");
        }
      });
    }
  }
</script>

<%- include('../../partials/footer') %>