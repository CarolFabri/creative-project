<%- include('../../partials/header') %>
<%- include('../../partials/nav') %>

<div class="post-section">
  <div class="posts-content-layout">

    <!-- LEFT SIDE: HOROSCOPE + NOTIFICATION CARD -->
    <div class="posts-left-side">
      

      <% if (isLoggedIn && horoscope) { %>

        <%
          let zodiacIcon = "";

          if (zodiac === "Aries") {
            zodiacIcon = "/images/zodiac/Aries.png";
          } else if (zodiac === "Taurus") {
            zodiacIcon = "/images/zodiac/Taurus.png";
          } else if (zodiac === "Gemini") {
            zodiacIcon = "/images/zodiac/Gemini.png";
          } else if (zodiac === "Cancer") {
            zodiacIcon = "/images/zodiac/cancer.png";
          } else if (zodiac === "Leo") {
            zodiacIcon = "/images/zodiac/leo.png";
          } else if (zodiac === "Virgo") {
            zodiacIcon = "/images/zodiac/virgo.png";
          } else if (zodiac === "Libra") {
            zodiacIcon = "/images/zodiac/libra.png";
          } else if (zodiac === "Scorpio") {
            zodiacIcon = "/images/zodiac/scorpio.png";
          } else if (zodiac === "Sagittarius") {
            zodiacIcon = "/images/zodiac/sagittarius.png";
          } else if (zodiac === "Capricorn") {
            zodiacIcon = "/images/zodiac/capricorn.png";
          } else if (zodiac === "Aquarius") {
            zodiacIcon = "/images/zodiac/aquarius.png";
          } else if (zodiac === "Pisces") {
            zodiacIcon = "/images/zodiac/pisces.png";
          }
        %>

        <%
          let zodiacEmoji = "";

          if (zodiac === "Aries") {
            zodiacEmoji = "♈";
          } else if (zodiac === "Taurus") {
            zodiacEmoji = "♉";
          } else if (zodiac === "Gemini") {
            zodiacEmoji = "♊";
          } else if (zodiac === "Cancer") {
            zodiacEmoji = "♋";
          } else if (zodiac === "Leo") {
            zodiacEmoji = "♌";
          } else if (zodiac === "Virgo") {
            zodiacEmoji = "♍";
          } else if (zodiac === "Libra") {
            zodiacEmoji = "♎";
          } else if (zodiac === "Scorpio") {
            zodiacEmoji = "♏";
          } else if (zodiac === "Sagittarius") {
            zodiacEmoji = "♐";
          } else if (zodiac === "Capricorn") {
            zodiacEmoji = "♑";
          } else if (zodiac === "Aquarius") {
            zodiacEmoji = "♒";
          } else if (zodiac === "Pisces") {
            zodiacEmoji = "♓";
          }
        %>

        <div class="mobile-left-icons">
          <button type="button" class="mobile-card-icon zodiac-emoji" id="openHoroscopeCard">
            <%= zodiacEmoji %>
          </button>

          <button type="button" class="mobile-card-icon" id="openNotificationCard">
            🔔
          </button>
        </div>

        <section class="daily-horoscope-card" id="horoscopeCard">

          <div class="daily-horoscope-inner">

            <!-- FRONT -->
            <div class="daily-horoscope-front">
              <div class="horoscope-front-content">
                <h3>Hello <%= usernameProfi || username %></h3>
                <% if (zodiacIcon) { %>
                  <img class="zodiac-icon-small" src="<%= zodiacIcon %>" alt="<%= zodiac %> icon">
                <% } %>

                <h4>Zodiac Sign For <%= zodiac %></h4>
                <p>Tap to see your travel horoscope</p>
              </div>
            </div>

            <!-- BACK -->
            <div class="daily-horoscope-back">
              <h3><%= zodiac %> Travel Horoscope</h3>

              <p><strong>Today’s energy:</strong> <%= horoscope.energy %></p>
              <p><strong>Best city for today:</strong> <%= horoscope.city %></p>
              <p><strong>Why this place matches your day:</strong> <%= horoscope.why %></p>
              <p><strong>Travel advice:</strong> <%= horoscope.advice %></p>
            </div>

          </div>

        </section>

      <% } %>

      <!-- NOTIFICATION CARD -->
      <% if (isLoggedIn) { %>

        <section class="notification-card" id="notificationCard">

          <h3>Activity</h3>

          <div class="notification-row">
            <span>Posts</span>
            <strong>
              <%= posts ? posts.filter(function(post) { return post.user === username; }).length : 0 %>
            </strong>
          </div>

          <div class="notification-row">
            <span>Notifications</span>
            <strong><%= notifications ? notifications.length : 0 %></strong>
          </div>

          <div class="notification-list">
            <% if (notifications && notifications.length > 0) { %>

              <% notifications.forEach(function(notification) { %>
                <div class="notification-item">
                  <p class="notification-text">
                    <strong><%= notification.fromUser %></strong>
                    <%= notification.type === "like" ? "liked your post." : "commented on your post." %>
                  </p>
                </div>
              <% }) %>

            <% } else { %>

              <div class="notification-item">
                <p class="notification-text">
                  No new notifications yet.
                </p>
              </div>

            <% } %>
          </div>

        </section>

      <% } %>

    </div> <!-- closes posts-left-side -->


    <!-- RIGHT SIDE: CREATE POST + RECENT POSTS -->
    <div class="posts-right-side">

      <% if (isLoggedIn) { %>

        <div class="create-post-wrapper">
          <h2>Create a new post</h2>

          <form class="create-post-form" action="/posts/create" method="POST" enctype="multipart/form-data">

            <input 
              type="file" 
              id="avatar" 
              name="avatar" 
              accept="image/png, image/jpeg"
              hidden
            >

            <div class="create-post-card">

              <!-- CAMERA + EMOJI BUTTONS -->
              <div class="post-actions upload-actions">
                <label for="avatar" class="upload-btn" aria-label="Upload image">📷</label>

                <button 
                  type="button" 
                  class="emoji-btn" 
                  id="emojiBtn" 
                  aria-label="Add emoji"
                >
                  😊
                </button>
              </div>

              <!-- EMOJI DROPDOWN -->
              <div class="emoji-picker" id="emojiPicker">
                <button type="button">✨</button>
                <button type="button">💜</button>
                <button type="button">🌙</button>
                <button type="button">⭐</button>
                <button type="button">🔥</button>
                <button type="button">🌸</button>
                <button type="button">😂</button>
                <button type="button">😍</button>
                <button type="button">🥰</button>
                <button type="button">🪐</button>
              </div>

              <!-- IMAGE PREVIEW -->
              <img 
                id="imagePreview" 
                class="image-preview" 
                alt="Selected image preview"
              >

              <!-- CAPTION -->
              <textarea 
                name="caption" 
                class="caption-input" 
                placeholder="Write something..."
                required
              ></textarea>

            </div>

            <div class="post-actions submit-actions">
              <button class="post-submit-btn" type="submit">Post</button>
            </div>

          </form>
        </div>

      <% } else { %>

        <div class="create-post-wrapper">
          <p>Please <a href="/login">log in</a> to create a post.</p>
        </div>

      <% } %>


      <!-- RECENT POSTS -->
      <% (posts || []).forEach(function(post) { %>

        <div class="post-card">

          <% const profileImage = post.profileImage ? post.profileImage : '/images/default-profile.png'; %>

          <div class="post-header">
            <img class="profile-icon" src="<%= profileImage %>" alt="profile image">
            <h3><%= post.user %></h3>
          </div>

          <!-- CAPTION NOW APPEARS ABOVE THE IMAGE -->
          <p class="post-caption"><%= post.caption %></p>

          <% if (post.image) { %>
            <img class="post-image" src="<%= post.image %>" alt="post image">
          <% } %>

          <div class="likes-row">

            <% if (isLoggedIn) { %>

              <% if ((post.likedBy || []).includes(username)) { %>
                <span class="liked-heart">♥</span>
              <% } else { %>
                <form class="like-form" action="/likepost" method="POST">
                  <input type="hidden" name="postId" value="<%= post._id %>">
                  <button class="heart-button" type="submit">♡</button>
                </form>
              <% } %>

            <% } else { %>
              <span class="heart-disabled">♡</span>
            <% } %>

            <span class="likes-count"><%= post.likes %></span>

          </div>

          <div class="comments-box">

            <% (post.comments || []).forEach(function(comment) { %>
              <p class="comments">
                <strong><%= comment.user %>:</strong> <%= comment.text %>
              </p>
            <% }) %>

            <% if (isLoggedIn) { %>
              <form class="comment-form" action="/addcomment" method="POST">
                <input type="hidden" name="postId" value="<%= post._id %>">
                <input type="text" name="text" placeholder="Write a comment" required>
                <button type="submit">Comment</button>
              </form>
            <% } %>

          </div>

        </div>

      <% }) %>

    </div> <!-- closes posts-right-side -->

  </div> <!-- closes posts-content-layout -->
</div> <!-- closes post-section -->

<script>
  // Followed youtube toturial for the card flip, but had lots of issue with the toggle and used chatGBT to help me with the logic and structure of the event listener 
  const openHoroscopeCard = document.getElementById("openHoroscopeCard");
  const openNotificationCard = document.getElementById("openNotificationCard");

  const horoscopeCard = document.getElementById("horoscopeCard");
  const notificationCard = document.getElementById("notificationCard");

  if (openHoroscopeCard && horoscopeCard && notificationCard) {
    openHoroscopeCard.addEventListener("click", function () {
      notificationCard.classList.remove("card-open");

      if (!horoscopeCard.classList.contains("card-open")) {
        // 1st click: open horoscope card
        horoscopeCard.classList.add("card-open");
        horoscopeCard.classList.remove("flipped");
      } else if (!horoscopeCard.classList.contains("flipped")) {
        // 2nd click: flip to back
        horoscopeCard.classList.add("flipped");
      } else {
        // 3rd click: close horoscope card and reset it
        horoscopeCard.classList.remove("card-open");
        horoscopeCard.classList.remove("flipped");
      }
    });
  }

  if (openNotificationCard && notificationCard && horoscopeCard) {
    openNotificationCard.addEventListener("click", function () {
      horoscopeCard.classList.remove("card-open");
      horoscopeCard.classList.remove("flipped");

      notificationCard.classList.toggle("card-open");
    });
  }

  if (horoscopeCard) {
    horoscopeCard.addEventListener("click", function () {
      if (window.innerWidth > 700) {
        horoscopeCard.classList.toggle("flipped");
      }
    });
  }

  // IMAGE PREVIEW WHEN USER SELECTS FILE
  const avatarInput = document.getElementById("avatar");
  const imagePreview = document.getElementById("imagePreview");
  const createPostCard = document.querySelector(".create-post-card");

  if (avatarInput && imagePreview && createPostCard) {
    avatarInput.addEventListener("change", function () {
      const file = avatarInput.files[0];

      if (!file) {
        imagePreview.style.display = "none";
        imagePreview.src = "";
        createPostCard.classList.remove("has-image");
        return;
      }

      imagePreview.src = URL.createObjectURL(file);
      createPostCard.classList.add("has-image");
    });
  }

  // EMOJI PICKER
  const emojiBtn = document.getElementById("emojiBtn");
  const emojiPicker = document.getElementById("emojiPicker");
  const captionInput = document.querySelector(".caption-input");

  if (emojiBtn && emojiPicker && captionInput) {
    emojiBtn.addEventListener("click", function () {
      emojiPicker.classList.toggle("open");
    });

    emojiPicker.querySelectorAll("button").forEach(function (button) {
      button.addEventListener("click", function () {
        captionInput.value += button.textContent;
        captionInput.focus();
        emojiPicker.classList.remove("open");
      });
    });

    document.addEventListener("click", function (event) {
      const clickedEmojiButton = emojiBtn.contains(event.target);
      const clickedPicker = emojiPicker.contains(event.target);

      if (!clickedEmojiButton && !clickedPicker) {
        emojiPicker.classList.remove("open");
      }
    });
  }
</script>

<%- include('../../partials/mobileBottomNav') %> 

<%- include('../../partials/footer') %>


<% if (!isLoggedIn) { %>
  <script>
    setTimeout(function () {
      window.location.href = "/login";
    }, 30000);
  </script>
<% } %>