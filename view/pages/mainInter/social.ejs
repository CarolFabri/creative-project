<%- include ('../../partials/header') %>
<%- include('../../partials/nav') %>

<h1>Zodiac Travel Social</h1>

<h2>Create a new post</h2>
<form action="/newpost" method="POST">
  <input type="text" name="image" placeholder="Image URL" required>
  <textarea name="caption" placeholder="Write your caption" required></textarea>
  <button type="submit">Post</button>
</form>

<hr>

<h2>Recent Posts</h2>

<% posts.forEach(post => { %>
  <div>
    <h3><%= post.user %></h3>
    <img src="<%= post.image %>" alt="post image" width="250">
    <p><%= post.caption %></p>

    <h4>Comments</h4>
    <% post.comments.forEach(comment => { %>
      <p><strong><%= comment.user %>:</strong> <%= comment.text %></p>
    <% }) %>

    <form action="/addcomment" method="POST">
      <input type="hidden" name="postId" value="<%= post._id %>">
      <input type="text" name="text" placeholder="Write a comment" required>
      <button type="submit">Comment</button>
    </form>
  </div>
  <hr>
<% }) %>

<%- include('../../partials/footer') %>